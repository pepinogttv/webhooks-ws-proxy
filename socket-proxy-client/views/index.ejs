<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Webhook Proxy Client</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { font-family: 'Inter', system-ui, -apple-system, sans-serif; }
    .fade-in { animation: fadeIn 0.3s ease-in; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
  </style>
</head>
<body class="bg-gray-950 text-gray-100 min-h-screen">
  <!-- Header -->
  <header class="bg-gray-900 border-b border-gray-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 bg-emerald-600/20 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/>
            </svg>
          </div>
          <h1 class="text-lg font-semibold">Webhook Proxy Client</h1>
          <!-- Connection status -->
          <div class="flex items-center gap-2 ml-4" id="connection-status">
            <% if (connected) { %>
              <span class="w-2.5 h-2.5 bg-emerald-400 rounded-full animate-pulse"></span>
              <span class="text-xs text-emerald-400">Conectado</span>
            <% } else { %>
              <span class="w-2.5 h-2.5 bg-red-400 rounded-full"></span>
              <span class="text-xs text-red-400">Desconectado</span>
            <% } %>
          </div>
        </div>
        <a href="/logout" class="text-sm text-gray-400 hover:text-gray-200 transition">Cerrar sesion</a>
      </div>
    </div>
  </header>

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Connection info -->
    <div class="mb-8">
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
        <div class="text-sm text-gray-400 mb-1">Servidor remoto</div>
        <div class="text-sm font-mono text-gray-200 truncate"><%= serverUrl %></div>
      </div>
    </div>

    <!-- Endpoint Mappings -->
    <div class="bg-gray-900 border border-gray-800 rounded-xl mb-8">
      <div class="p-5 border-b border-gray-800">
        <h2 class="text-lg font-semibold">Mapeo de Endpoints</h2>
        <p class="text-sm text-gray-500 mt-1">Configura la URL local de destino para cada webhook</p>
      </div>

      <% if (endpoints.length === 0) { %>
        <div class="p-8 text-center text-gray-500">
          No hay endpoints configurados en el servidor
        </div>
      <% } else { %>
        <div class="divide-y divide-gray-800">
          <% endpoints.forEach(endpoint => { %>
            <div class="p-4 hover:bg-gray-800/30 transition" id="mapping-<%= endpoint.key %>">
              <div class="flex items-center gap-3 mb-3">
                <span class="px-2.5 py-1 text-xs font-mono font-bold rounded-md uppercase
                  <% if (endpoint.method === 'get') { %>bg-green-500/10 text-green-400 border border-green-500/20
                  <% } else if (endpoint.method === 'post') { %>bg-blue-500/10 text-blue-400 border border-blue-500/20
                  <% } else if (endpoint.method === 'put') { %>bg-yellow-500/10 text-yellow-400 border border-yellow-500/20
                  <% } else { %>bg-red-500/10 text-red-400 border border-red-500/20<% } %>
                "><%= endpoint.method %></span>
                <span class="font-mono text-sm text-gray-300"><span class="text-gray-600">/webhooks</span><%= endpoint.path %></span>
                <span class="text-xs text-gray-600">(<%= endpoint.key %>)</span>
              </div>
              <div class="flex items-center gap-3">
                <span class="text-gray-500 text-sm shrink-0">URL local:</span>
                <div class="flex items-center gap-2 flex-1">
                  <input
                    type="text"
                    id="local-<%= endpoint.key %>"
                    value="<%= endpoint.localUrl || '' %>"
                    placeholder="http://localhost:3000<%= endpoint.path %>"
                    class="flex-1 px-3 py-2 bg-gray-800 border border-gray-700 rounded-lg text-gray-100 placeholder-gray-600 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent text-sm font-mono"
                  />
                  <button
                    onclick="updateMapping('<%= endpoint.key %>', '<%= endpoint.path %>')"
                    class="px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-medium rounded-lg transition shrink-0"
                  >
                    Guardar
                  </button>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <!-- Forward Log -->
    <div class="bg-gray-900 border border-gray-800 rounded-xl">
      <div class="flex items-center justify-between p-5 border-b border-gray-800">
        <h2 class="text-lg font-semibold">Log de reenvios</h2>
        <span class="text-xs text-gray-500">Ultimos webhooks reenviados</span>
      </div>
      <div class="divide-y divide-gray-800 max-h-96 overflow-y-auto" id="forward-log">
        <% if (forwardLog.length === 0) { %>
          <div class="p-8 text-center text-gray-500" id="empty-log">
            Sin actividad todavia. Los webhooks reenviados apareceran aqui.
          </div>
        <% } %>
        <% forwardLog.forEach(entry => { %>
          <div class="p-3 px-5 flex items-center gap-3 text-sm">
            <span class="px-2 py-0.5 text-xs font-mono font-bold rounded uppercase
              <% if (entry.method === 'get') { %>bg-green-500/10 text-green-400
              <% } else { %>bg-blue-500/10 text-blue-400<% } %>
            "><%= entry.method %></span>
            <span class="font-mono text-gray-400 text-xs"><%= entry.webhookPath %></span>
            <svg class="w-3 h-3 text-gray-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            <span class="font-mono text-gray-300 text-xs"><%= entry.localUrl %></span>
            <span class="ml-auto flex items-center gap-2">
              <% if (entry.status === 'success') { %>
                <span class="w-2 h-2 bg-emerald-400 rounded-full"></span>
                <span class="text-emerald-400 text-xs"><%= entry.statusCode %></span>
              <% } else if (entry.status === 'error') { %>
                <span class="w-2 h-2 bg-red-400 rounded-full"></span>
                <span class="text-red-400 text-xs truncate max-w-[150px]" title="<%= entry.error %>"><%= entry.error %></span>
              <% } else { %>
                <span class="w-2 h-2 bg-yellow-400 rounded-full animate-pulse"></span>
                <span class="text-yellow-400 text-xs">pending</span>
              <% } %>
            </span>
            <span class="text-gray-600 text-xs shrink-0"><%= new Date(entry.timestamp).toLocaleTimeString() %></span>
          </div>
        <% }) %>
      </div>
    </div>
  </main>

  <script>
    async function updateMapping(key, webhookPath) {
      const input = document.getElementById("local-" + key);
      const localUrl = input.value.trim();
      if (!localUrl) {
        alert("La URL local no puede estar vacia");
        return;
      }

      try {
        const res = await fetch("/api/map-endpoint", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ path: webhookPath, localUrl }),
        });
        const data = await res.json();
        if (data.success) {
          input.classList.add("ring-2", "ring-emerald-500");
          setTimeout(() => input.classList.remove("ring-2", "ring-emerald-500"), 1500);
        }
      } catch (err) {
        alert("Error: " + err.message);
      }
    }

    // Poll for status updates
    setInterval(async () => {
      try {
        const res = await fetch("/api/status");
        if (res.ok) {
          const data = await res.json();

          // Update connection status
          const statusEl = document.getElementById("connection-status");
          if (data.connected) {
            statusEl.innerHTML = `
              <span class="w-2.5 h-2.5 bg-emerald-400 rounded-full animate-pulse"></span>
              <span class="text-xs text-emerald-400">Conectado</span>`;
          } else {
            statusEl.innerHTML = `
              <span class="w-2.5 h-2.5 bg-red-400 rounded-full"></span>
              <span class="text-xs text-red-400">Desconectado</span>`;
          }

          // Update log
          if (data.forwardLog && data.forwardLog.length > 0) {
            const logEl = document.getElementById("forward-log");
            const emptyLog = document.getElementById("empty-log");
            if (emptyLog) emptyLog.remove();

            logEl.innerHTML = "";
            data.forwardLog.forEach(entry => {
              const methodClass = entry.method === "get"
                ? "bg-green-500/10 text-green-400"
                : "bg-blue-500/10 text-blue-400";

              let statusHtml;
              if (entry.status === "success") {
                statusHtml = `<span class="w-2 h-2 bg-emerald-400 rounded-full"></span><span class="text-emerald-400 text-xs">${entry.statusCode}</span>`;
              } else if (entry.status === "error") {
                statusHtml = `<span class="w-2 h-2 bg-red-400 rounded-full"></span><span class="text-red-400 text-xs truncate max-w-[150px]" title="${entry.error}">${entry.error}</span>`;
              } else {
                statusHtml = `<span class="w-2 h-2 bg-yellow-400 rounded-full animate-pulse"></span><span class="text-yellow-400 text-xs">pending</span>`;
              }

              logEl.innerHTML += `
                <div class="p-3 px-5 flex items-center gap-3 text-sm fade-in">
                  <span class="px-2 py-0.5 text-xs font-mono font-bold rounded uppercase ${methodClass}">${entry.method}</span>
                  <span class="font-mono text-gray-400 text-xs">${entry.webhookPath}</span>
                  <svg class="w-3 h-3 text-gray-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                  <span class="font-mono text-gray-300 text-xs">${entry.localUrl}</span>
                  <span class="ml-auto flex items-center gap-2">${statusHtml}</span>
                  <span class="text-gray-600 text-xs shrink-0">${new Date(entry.timestamp).toLocaleTimeString()}</span>
                </div>`;
            });
          }
        }
      } catch(e) {}
    }, 3000);
  </script>
</body>
</html>

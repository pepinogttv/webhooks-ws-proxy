<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Webhook Relay</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          fontFamily: {
            mono: ['ui-monospace', 'SFMono-Regular', 'Menlo', 'Monaco', 'Consolas', 'monospace'],
          }
        }
      }
    }
  </script>
  <style>
    body { background: #0f172a; }
    .status-dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; }
    .status-dot.green { background: #22c55e; box-shadow: 0 0 6px #22c55e80; }
    .status-dot.red { background: #ef4444; box-shadow: 0 0 6px #ef444480; }
    .log-entry { transition: all 0.2s ease; }
    .log-entry:hover { background: #1e293b; }
    .log-entry .details { max-height: 0; overflow: hidden; transition: max-height 0.3s ease; }
    .log-entry.expanded .details { max-height: 2000px; }
    .fade-in { animation: fadeIn 0.25s ease-in; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(-4px); } to { opacity: 1; transform: translateY(0); } }
    .copy-feedback { transition: opacity 0.2s ease; }
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: #0f172a; }
    ::-webkit-scrollbar-thumb { background: #334155; border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: #475569; }
  </style>
</head>
<body class="min-h-screen text-slate-200 font-sans">

  <!-- Header -->
  <header class="border-b border-slate-700/50 bg-slate-900/80 backdrop-blur-sm sticky top-0 z-50">
    <div class="max-w-6xl mx-auto px-4 h-14 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-amber-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" />
          </svg>
          <h1 class="text-lg font-semibold text-white tracking-tight">Webhook Relay</h1>
        </div>
        <div id="connection-status" class="flex items-center gap-1.5 text-xs text-slate-400 ml-4">
          <span class="status-dot red" id="status-dot"></span>
          <span id="status-text">Disconnected</span>
        </div>
      </div>
      <a href="https://github.com/pepinogttv/webhook-relay" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-slate-200 transition-colors">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
      </a>
    </div>
  </header>

  <main class="max-w-6xl mx-auto px-4 py-6 space-y-6">

    <!-- Safari Warning Banner -->
    <div id="safari-banner" class="hidden bg-amber-900/40 border border-amber-600/50 rounded-lg px-4 py-3 flex items-center justify-between">
      <div class="flex items-center gap-2 text-amber-200 text-sm">
        <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <span>Safari does not support forwarding to localhost from HTTPS. Use Chrome, Firefox, or Edge.</span>
      </div>
      <button onclick="document.getElementById('safari-banner').classList.add('hidden')" class="text-amber-400 hover:text-amber-200 ml-4 flex-shrink-0">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Channel Info Card -->
    <div class="bg-slate-800/50 border border-slate-700/50 rounded-xl p-5 space-y-4">
      <div class="flex flex-col sm:flex-row sm:items-center gap-3">
        <div class="flex-1 min-w-0">
          <label class="text-xs text-slate-400 uppercase tracking-wider font-medium mb-1.5 block">Webhook URL</label>
          <div class="flex items-center gap-2">
            <div class="flex-1 bg-slate-900 border border-slate-600/50 rounded-lg px-3 py-2 font-mono text-sm text-emerald-400 truncate" id="webhook-url"></div>
            <button onclick="copyUrl()" id="copy-btn" class="px-3 py-2 bg-slate-700 hover:bg-slate-600 text-slate-200 rounded-lg text-sm font-medium transition-colors whitespace-nowrap flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
              </svg>
              <span id="copy-text">Copy</span>
            </button>
          </div>
        </div>
        <div class="sm:pt-5">
          <button onclick="newChannel()" class="px-4 py-2 bg-indigo-600 hover:bg-indigo-500 text-white rounded-lg text-sm font-medium transition-colors whitespace-nowrap">
            New Channel
          </button>
        </div>
      </div>

      <div class="flex flex-wrap gap-4 text-sm">
        <div class="flex items-center gap-2 text-slate-400">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          <span>Tabs: <span id="stat-tabs" class="text-slate-200">0</span></span>
        </div>
        <div class="flex items-center gap-2 text-slate-400">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
          <span>Webhooks received: <span id="stat-total" class="text-slate-200">0</span></span>
        </div>
      </div>

      <p class="text-xs text-slate-500">Any POST/GET/PUT/DELETE to this URL will appear below in real-time.</p>
    </div>

    <!-- How Forwarding Works (collapsible) -->
    <div class="bg-slate-800/50 border border-slate-700/50 rounded-xl">
      <details class="group">
        <summary class="flex items-center gap-2 cursor-pointer px-5 py-4 text-sm font-semibold text-slate-300 uppercase tracking-wider select-none list-none hover:text-slate-100 transition-colors">
          <svg class="w-4 h-4 text-slate-400 transition-transform duration-200 group-open:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
          How does forwarding work?
        </summary>
        <div class="px-5 pb-5 space-y-5 text-sm text-slate-300 border-t border-slate-700/30">

          <!-- Your Webhook URL -->
          <div class="pt-4">
            <h3 class="text-xs font-semibold text-slate-200 uppercase tracking-wider mb-2">Your Webhook URL</h3>
            <p class="text-slate-400 mb-2">Your base URL is shown above. You can append any path when configuring webhooks in external services:</p>
            <div class="bg-slate-900/50 rounded-lg p-3 font-mono text-xs text-emerald-400 space-y-1">
              <div><span class="text-slate-500">{baseUrl}</span>chatwoot</div>
              <div><span class="text-slate-500">{baseUrl}</span>mercadopago/notifications</div>
              <div><span class="text-slate-500">{baseUrl}</span>stripe/events</div>
              <div><span class="text-slate-500">{baseUrl}</span>anything/you/want</div>
            </div>
          </div>

          <!-- Default Target -->
          <div>
            <h3 class="text-xs font-semibold text-slate-200 uppercase tracking-wider mb-2">Default Target <span class="normal-case text-slate-500 font-normal">(simplest setup)</span></h3>
            <p class="text-slate-400 mb-2">Set a base URL like <code class="text-slate-300 bg-slate-900/50 px-1.5 py-0.5 rounded text-xs">http://localhost:4000</code>. All webhooks get forwarded there, preserving the original path:</p>
            <div class="bg-slate-900/50 rounded-lg p-3 font-mono text-xs space-y-1">
              <div><span class="text-slate-500">/w/{id}/</span><span class="text-slate-300">chatwoot</span> <span class="text-slate-500 mx-1">&rarr;</span> <span class="text-indigo-400">http://localhost:4000/chatwoot</span></div>
              <div><span class="text-slate-500">/w/{id}/</span><span class="text-slate-300">stripe/events</span> <span class="text-slate-500 mx-1">&rarr;</span> <span class="text-indigo-400">http://localhost:4000/stripe/events</span></div>
            </div>
          </div>

          <!-- Specific Rules -->
          <div>
            <h3 class="text-xs font-semibold text-slate-200 uppercase tracking-wider mb-2">Specific Rules <span class="normal-case text-slate-500 font-normal">(overrides)</span></h3>
            <p class="text-slate-400 mb-2">When a webhook path needs to go somewhere different than what the Default Target would produce, add a specific rule:</p>
            <div class="bg-slate-900/50 rounded-lg p-3 font-mono text-xs mb-2">
              <div>Rule: <span class="text-slate-300">stripe/events</span> <span class="text-slate-500 mx-1">&rarr;</span> <span class="text-indigo-400">http://localhost:5000/webhooks/stripe</span></div>
            </div>
            <p class="text-slate-400">Now stripe goes to port 5000 while everything else still goes to the Default Target.</p>
          </div>

          <!-- Priority -->
          <div class="bg-slate-900/50 rounded-lg p-3 flex items-center gap-2 text-xs">
            <span class="font-semibold text-slate-200">Priority:</span>
            <span class="text-indigo-400 font-medium">Specific Rule</span>
            <span class="text-slate-500">&gt;</span>
            <span class="text-emerald-400 font-medium">Default Target</span>
            <span class="text-slate-500">&gt;</span>
            <span class="text-slate-400 font-medium">Skip</span>
          </div>

        </div>
      </details>
    </div>

    <!-- Forwarding Rules -->
    <div class="bg-slate-800/50 border border-slate-700/50 rounded-xl p-5 space-y-4">
      <h2 class="text-sm font-semibold text-slate-300 uppercase tracking-wider">Forwarding Rules</h2>

      <div>
        <label class="text-xs text-slate-400 mb-1.5 block">Default Target <span class="text-slate-500">(catch-all, preserves original path)</span></label>
        <input type="text" id="default-target" placeholder="http://localhost:3000"
          class="w-full bg-slate-900 border border-slate-600/50 rounded-lg px-3 py-2 font-mono text-sm text-slate-200 placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500/50 transition" />
      </div>

      <div id="mappings-list" class="space-y-2"></div>

      <button onclick="addMapping()" class="flex items-center gap-1.5 text-sm text-indigo-400 hover:text-indigo-300 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
        </svg>
        Add Rule
      </button>
    </div>

    <!-- Webhook Log -->
    <div class="bg-slate-800/50 border border-slate-700/50 rounded-xl p-5 space-y-4">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-2">
          <h2 class="text-sm font-semibold text-slate-300 uppercase tracking-wider">Incoming Webhooks</h2>
          <span id="log-count-badge" class="bg-slate-700 text-slate-300 text-xs font-mono px-2 py-0.5 rounded-full">0</span>
        </div>
        <button onclick="clearLog()" class="text-xs text-slate-500 hover:text-slate-300 transition-colors">Clear Log</button>
      </div>

      <div id="webhook-log" class="space-y-1 max-h-[600px] overflow-y-auto"></div>

      <div id="log-empty" class="text-center py-12 text-slate-500 text-sm">
        <svg class="w-10 h-10 mx-auto mb-3 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.288 15.038a5.25 5.25 0 017.424 0M5.106 11.856c3.807-3.808 9.98-3.808 13.788 0M1.924 8.674c5.565-5.565 14.587-5.565 20.152 0M12.53 18.22l-.53.53-.53-.53a.75.75 0 011.06 0z" />
        </svg>
        Waiting for webhooks...
      </div>
    </div>

    <!-- Footer / Limitations -->
    <div class="border-t border-slate-700/30 pt-4 pb-8">
      <details class="group">
        <summary class="text-xs text-slate-500 cursor-pointer hover:text-slate-400 transition-colors list-none flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
          Limitations
        </summary>
        <ul class="mt-3 space-y-1.5 text-xs text-slate-500 ml-5">
          <li>Browser tab must remain open for forwarding to work.</li>
          <li>Safari is not supported for forwarding to localhost (WebKit blocks mixed-content fetch).</li>
          <li>Chrome will show a one-time Local Network Access permission prompt.</li>
          <li>Some HTTP headers (<code class="text-slate-400">Host</code>, <code class="text-slate-400">Cookie</code>, <code class="text-slate-400">Origin</code>) cannot be forwarded by the browser.</li>
          <li>If your local service does not have CORS headers, forwarding still works but the response will be opaque (no status code or body visible).</li>
        </ul>
      </details>
    </div>
  </main>

  <script src="/socket.io/socket.io.js"></script>
  <script>
    // ─── Channel Management ───────────────────────────────────────────
    let channelId = '<%= channelId %>' !== 'null' && '<%= channelId %>' !== ''
      ? '<%= channelId %>'
      : localStorage.getItem('wsproxy:channelId');
    if (!channelId) {
      channelId = crypto.randomUUID();
    }
    localStorage.setItem('wsproxy:channelId', channelId);
    if (!window.location.pathname.startsWith('/ch/')) {
      history.replaceState(null, '', '/ch/' + channelId);
    }

    // Update webhook URL display
    const webhookBaseUrl = window.location.origin + '/w/' + channelId + '/';
    document.getElementById('webhook-url').textContent = webhookBaseUrl;

    // ─── Safari Detection ─────────────────────────────────────────────
    const isSafari = /^((?!chrome|android).)*safari/i.test(navigator.userAgent);
    if (isSafari) document.getElementById('safari-banner').classList.remove('hidden');

    // ─── BroadcastChannel (multi-tab coordination) ────────────────────
    let bc;
    const claimedByOther = new Set();
    const localClaims = new Set();

    function getBroadcastChannel() {
      if (!bc) {
        bc = new BroadcastChannel('wsproxy:' + channelId);
        bc.onmessage = function(e) {
          if (e.data.type === 'claim' && !localClaims.has(e.data.webhookId)) {
            claimedByOther.add(e.data.webhookId);
          }
        };
      }
      return bc;
    }
    getBroadcastChannel();

    // ─── Mappings (localStorage) ──────────────────────────────────────
    const MAPPINGS_KEY = 'wsproxy:mappings:' + channelId;
    const DEFAULT_TARGET_KEY = 'wsproxy:defaultTarget:' + channelId;

    function loadMappings() {
      try {
        return JSON.parse(localStorage.getItem(MAPPINGS_KEY)) || [];
      } catch (e) {
        return [];
      }
    }

    function saveMappings(mappings) {
      localStorage.setItem(MAPPINGS_KEY, JSON.stringify(mappings));
    }

    function loadDefaultTarget() {
      return localStorage.getItem(DEFAULT_TARGET_KEY) || '';
    }

    function saveDefaultTarget(val) {
      localStorage.setItem(DEFAULT_TARGET_KEY, val);
    }

    // Initialize default target input
    const defaultTargetInput = document.getElementById('default-target');
    defaultTargetInput.value = loadDefaultTarget();
    defaultTargetInput.addEventListener('blur', function() {
      saveDefaultTarget(this.value.trim());
    });
    defaultTargetInput.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') this.blur();
    });

    function renderMappings() {
      const list = document.getElementById('mappings-list');
      list.innerHTML = '';
      const mappings = loadMappings();
      mappings.forEach(function(m, idx) {
        const row = document.createElement('div');
        row.className = 'flex items-center gap-2';

        const patternInput = document.createElement('input');
        patternInput.type = 'text';
        patternInput.value = m.pattern;
        patternInput.placeholder = 'mercadopago/notifications';
        patternInput.className = 'flex-1 bg-slate-900 border border-slate-600/50 rounded-lg px-3 py-2 font-mono text-sm text-slate-200 placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500/50 transition';
        patternInput.addEventListener('blur', function() {
          const all = loadMappings();
          all[idx].pattern = this.value.trim();
          saveMappings(all);
        });

        const arrow = document.createElement('span');
        arrow.className = 'text-slate-500 text-lg flex-shrink-0';
        arrow.textContent = '\u2192';

        const targetInput = document.createElement('input');
        targetInput.type = 'text';
        targetInput.value = m.target;
        targetInput.placeholder = 'http://localhost:8080/api/webhooks/mp';
        targetInput.className = 'flex-1 bg-slate-900 border border-slate-600/50 rounded-lg px-3 py-2 font-mono text-sm text-slate-200 placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500/50 transition';
        targetInput.addEventListener('blur', function() {
          const all = loadMappings();
          all[idx].target = this.value.trim();
          saveMappings(all);
        });

        const delBtn = document.createElement('button');
        delBtn.className = 'text-slate-500 hover:text-red-400 transition-colors flex-shrink-0 p-1';
        delBtn.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>';
        delBtn.addEventListener('click', function() {
          const all = loadMappings();
          all.splice(idx, 1);
          saveMappings(all);
          renderMappings();
        });

        row.appendChild(patternInput);
        row.appendChild(arrow);
        row.appendChild(targetInput);
        row.appendChild(delBtn);
        list.appendChild(row);
      });
    }

    function addMapping() {
      const mappings = loadMappings();
      mappings.push({ pattern: '', target: '' });
      saveMappings(mappings);
      renderMappings();
      // Focus the new pattern input
      const list = document.getElementById('mappings-list');
      const inputs = list.querySelectorAll('input');
      if (inputs.length >= 2) {
        inputs[inputs.length - 2].focus();
      }
    }

    renderMappings();

    // ─── Resolve Target ───────────────────────────────────────────────
    function resolveTarget(webhookPath) {
      const mappings = loadMappings();
      const defaultTarget = loadDefaultTarget();

      // Normalize path (remove leading slash)
      const normalizedPath = webhookPath.replace(/^\/+/, '');

      // Exact match
      for (let i = 0; i < mappings.length; i++) {
        const m = mappings[i];
        if (m.pattern && m.target && m.pattern === normalizedPath) {
          return m.target;
        }
      }

      // Prefix match
      for (let i = 0; i < mappings.length; i++) {
        const m = mappings[i];
        if (m.pattern && m.target && normalizedPath.startsWith(m.pattern)) {
          return m.target;
        }
      }

      // Default target fallback
      if (defaultTarget) {
        const base = defaultTarget.replace(/\/+$/, '');
        return base + '/' + normalizedPath;
      }

      return null;
    }

    // ─── Filter Headers ───────────────────────────────────────────────
    const FORBIDDEN_HEADERS = new Set([
      'host', 'connection', 'content-length', 'transfer-encoding',
      'origin', 'referer', 'cookie', 'set-cookie', 'keep-alive',
      'trailer', 'upgrade', 'via', 'expect', 'te', 'dnt', 'date',
    ]);

    function filterHeaders(headers) {
      const filtered = {};
      for (const key in headers) {
        const lower = key.toLowerCase();
        if (FORBIDDEN_HEADERS.has(lower)) continue;
        if (lower.startsWith('sec-') || lower.startsWith('proxy-')) continue;
        filtered[key] = headers[key];
      }
      return filtered;
    }

    // ─── Socket.IO Connection ─────────────────────────────────────────
    const socket = io();
    socket.on('connect', function() {
      updateConnectionStatus(true);
      socket.emit('join', { channelId: channelId });
    });
    socket.on('disconnect', function() {
      updateConnectionStatus(false);
    });
    socket.on('webhook', handleWebhook);
    socket.on('webhook:buffered', function(webhooks) {
      webhooks.forEach(handleWebhook);
    });
    socket.on('channel:stats', function(data) {
      document.getElementById('stat-tabs').textContent = data.connectedSockets || 0;
      document.getElementById('stat-total').textContent = data.totalReceived || 0;
    });
    socket.on('forward:result', function(data) {
      // Update log entry forwarded by another tab
      const entry = document.querySelector('[data-webhook-id="' + data.webhookId + '"]');
      if (entry && !localClaims.has(data.webhookId)) {
        if (data.success) {
          updateEntryStatus(entry, 'handled-other-tab', 'Forwarded by another tab');
        } else {
          updateEntryStatus(entry, 'error-other-tab', 'Error in another tab: ' + (data.error || 'unknown'));
        }
      }
    });

    function updateConnectionStatus(connected) {
      const dot = document.getElementById('status-dot');
      const text = document.getElementById('status-text');
      if (connected) {
        dot.className = 'status-dot green';
        text.textContent = 'Connected';
      } else {
        dot.className = 'status-dot red';
        text.textContent = 'Disconnected';
      }
    }

    // ─── Webhook Log ──────────────────────────────────────────────────
    let logCount = 0;
    const MAX_LOG_ENTRIES = 200;
    let userScrolled = false;

    // ─── Log Persistence (localStorage) ────────────────────────────────
    const LOG_STORAGE_KEY = 'wsproxy:log:' + channelId;
    let logEntries = []; // in-memory mirror of localStorage log

    function saveLog() {
      try {
        localStorage.setItem(LOG_STORAGE_KEY, JSON.stringify(logEntries));
      } catch (e) {
        // localStorage full — evict oldest half and retry
        logEntries = logEntries.slice(0, Math.floor(logEntries.length / 2));
        try {
          localStorage.setItem(LOG_STORAGE_KEY, JSON.stringify(logEntries));
        } catch (e2) {
          // give up silently
        }
      }
    }

    function loadLog() {
      try {
        var raw = localStorage.getItem(LOG_STORAGE_KEY);
        return raw ? JSON.parse(raw) : [];
      } catch (e) {
        return [];
      }
    }

    function addLogEntryToStore(webhook, status, statusMessage, targetUrl) {
      logEntries.unshift({
        id: webhook.id,
        timestamp: webhook.timestamp,
        method: webhook.method,
        path: webhook.path,
        headers: webhook.headers,
        rawBodyBase64: webhook.rawBodyBase64,
        query: webhook.query,
        status: status || 'received',
        statusMessage: statusMessage || 'received',
        targetUrl: targetUrl || null,
      });
      // Enforce max cap
      if (logEntries.length > MAX_LOG_ENTRIES) {
        logEntries = logEntries.slice(0, MAX_LOG_ENTRIES);
      }
      saveLog();
    }

    var _restoringLog = false; // flag to skip localStorage writes during restore

    function updateLogEntryInStore(webhookId, status, statusMessage, targetUrl) {
      if (_restoringLog) return;
      for (var i = 0; i < logEntries.length; i++) {
        if (logEntries[i].id === webhookId) {
          logEntries[i].status = status;
          logEntries[i].statusMessage = statusMessage;
          if (targetUrl !== undefined) {
            logEntries[i].targetUrl = targetUrl;
          }
          break;
        }
      }
      saveLog();
    }

    const logContainer = document.getElementById('webhook-log');
    logContainer.addEventListener('scroll', function() {
      const atBottom = logContainer.scrollHeight - logContainer.scrollTop - logContainer.clientHeight < 40;
      userScrolled = !atBottom;
    });

    function formatTime(ts) {
      const d = new Date(ts);
      return d.toLocaleTimeString('en-US', { hour12: false, hour: '2-digit', minute: '2-digit', second: '2-digit' });
    }

    function getMethodColor(method) {
      const colors = {
        'GET': 'text-emerald-400',
        'POST': 'text-blue-400',
        'PUT': 'text-amber-400',
        'PATCH': 'text-orange-400',
        'DELETE': 'text-red-400',
      };
      return colors[method.toUpperCase()] || 'text-slate-400';
    }

    function getStatusBorderColor(status) {
      switch (status) {
        case 'success': return 'border-l-emerald-500';
        case 'sent-no-cors': return 'border-l-amber-500';
        case 'error': case 'error-other-tab': return 'border-l-red-500';
        case 'skipped': case 'handled-other-tab': return 'border-l-slate-500';
        case 'forwarding': return 'border-l-blue-500';
        default: return 'border-l-slate-600';
      }
    }

    function getStatusDotColor(status) {
      switch (status) {
        case 'success': return 'bg-emerald-500';
        case 'sent-no-cors': return 'bg-amber-500';
        case 'error': case 'error-other-tab': return 'bg-red-500';
        case 'skipped': case 'handled-other-tab': return 'bg-slate-500';
        case 'forwarding': return 'bg-blue-500';
        default: return 'bg-slate-600';
      }
    }

    function addLogEntry(webhook) {
      const emptyState = document.getElementById('log-empty');
      if (emptyState) emptyState.classList.add('hidden');

      logCount++;
      document.getElementById('log-count-badge').textContent = logCount;

      const entry = document.createElement('div');
      entry.className = 'log-entry border-l-2 border-l-slate-600 rounded-r-lg bg-slate-800/30 cursor-pointer fade-in';
      entry.dataset.webhookId = webhook.id;

      // Summary row
      const summary = document.createElement('div');
      summary.className = 'flex items-center gap-2 px-3 py-2 text-sm';

      const dot = document.createElement('span');
      dot.className = 'w-2 h-2 rounded-full bg-slate-600 flex-shrink-0 transition-colors';
      dot.dataset.role = 'status-dot';

      const time = document.createElement('span');
      time.className = 'text-slate-500 font-mono text-xs flex-shrink-0';
      time.textContent = formatTime(webhook.timestamp);

      const method = document.createElement('span');
      method.className = 'font-mono text-xs font-bold flex-shrink-0 ' + getMethodColor(webhook.method);
      method.textContent = webhook.method;

      const path = document.createElement('span');
      path.className = 'font-mono text-xs text-slate-300 truncate';
      path.textContent = '/' + webhook.path;

      const statusMsg = document.createElement('span');
      statusMsg.className = 'text-xs text-slate-500 ml-auto flex-shrink-0 truncate max-w-[200px]';
      statusMsg.dataset.role = 'status-message';
      statusMsg.textContent = 'received';

      summary.appendChild(dot);
      summary.appendChild(time);
      summary.appendChild(method);
      summary.appendChild(path);
      summary.appendChild(statusMsg);

      // Details panel
      const details = document.createElement('div');
      details.className = 'details';

      const detailsInner = document.createElement('div');
      detailsInner.className = 'px-3 pb-3 pt-1 border-t border-slate-700/30 space-y-3';

      // Forward target
      const forwardSection = document.createElement('div');
      const forwardLabel = document.createElement('div');
      forwardLabel.className = 'text-xs text-slate-500 mb-1';
      forwardLabel.textContent = 'Forward Target';
      const forwardValue = document.createElement('div');
      forwardValue.className = 'font-mono text-xs text-slate-400';
      forwardValue.dataset.role = 'forward-target';
      forwardValue.textContent = 'Resolving...';
      forwardSection.appendChild(forwardLabel);
      forwardSection.appendChild(forwardValue);

      // Forward result
      const resultSection = document.createElement('div');
      const resultLabel = document.createElement('div');
      resultLabel.className = 'text-xs text-slate-500 mb-1';
      resultLabel.textContent = 'Result';
      const resultValue = document.createElement('div');
      resultValue.className = 'font-mono text-xs text-slate-400';
      resultValue.dataset.role = 'forward-result';
      resultValue.textContent = 'Pending...';
      resultSection.appendChild(resultLabel);
      resultSection.appendChild(resultValue);

      // Headers
      const headersSection = document.createElement('div');
      const headersLabel = document.createElement('div');
      headersLabel.className = 'text-xs text-slate-500 mb-1';
      headersLabel.textContent = 'Headers';
      const headersValue = document.createElement('pre');
      headersValue.className = 'font-mono text-xs text-slate-400 bg-slate-900/50 rounded p-2 overflow-x-auto max-h-40 overflow-y-auto';
      if (webhook.headers) {
        const headerLines = [];
        for (const key in webhook.headers) {
          headerLines.push(key + ': ' + webhook.headers[key]);
        }
        headersValue.textContent = headerLines.join('\n');
      } else {
        headersValue.textContent = '(none)';
      }
      headersSection.appendChild(headersLabel);
      headersSection.appendChild(headersValue);

      // Body
      const bodySection = document.createElement('div');
      const bodyLabel = document.createElement('div');
      bodyLabel.className = 'text-xs text-slate-500 mb-1';
      bodyLabel.textContent = 'Body';
      const bodyValue = document.createElement('pre');
      bodyValue.className = 'font-mono text-xs text-slate-400 bg-slate-900/50 rounded p-2 overflow-x-auto max-h-60 overflow-y-auto';
      if (webhook.rawBodyBase64) {
        try {
          const decoded = atob(webhook.rawBodyBase64);
          try {
            const parsed = JSON.parse(decoded);
            bodyValue.textContent = JSON.stringify(parsed, null, 2);
          } catch (e) {
            // Not JSON, show raw (truncated if too long)
            bodyValue.textContent = decoded.length > 2000 ? decoded.substring(0, 2000) + '\n... (truncated)' : decoded;
          }
        } catch (e) {
          bodyValue.textContent = '(binary data, ' + webhook.rawBodyBase64.length + ' bytes base64)';
        }
      } else {
        bodyValue.textContent = '(empty)';
      }
      bodySection.appendChild(bodyLabel);
      bodySection.appendChild(bodyValue);

      detailsInner.appendChild(forwardSection);
      detailsInner.appendChild(resultSection);
      detailsInner.appendChild(headersSection);
      detailsInner.appendChild(bodySection);
      details.appendChild(detailsInner);

      entry.appendChild(summary);
      entry.appendChild(details);

      // Toggle expand on click
      summary.addEventListener('click', function() {
        entry.classList.toggle('expanded');
      });

      // Insert at top
      logContainer.insertBefore(entry, logContainer.firstChild);

      // Trim excess entries
      while (logContainer.children.length > MAX_LOG_ENTRIES) {
        logContainer.removeChild(logContainer.lastChild);
      }

      // Auto-scroll
      if (!userScrolled) {
        logContainer.scrollTop = 0;
      }

      // Persist to localStorage (skip for restored entries)
      if (!webhook._restored) {
        addLogEntryToStore(webhook, 'received', 'received', null);
      }

      return entry;
    }

    function updateEntryStatus(entry, status, message) {
      if (!entry) return;
      const dot = entry.querySelector('[data-role="status-dot"]');
      const msg = entry.querySelector('[data-role="status-message"]');
      const forwardTarget = entry.querySelector('[data-role="forward-target"]');
      const forwardResult = entry.querySelector('[data-role="forward-result"]');

      if (dot) {
        dot.className = 'w-2 h-2 rounded-full flex-shrink-0 transition-colors ' + getStatusDotColor(status);
      }

      // Update border color
      entry.className = entry.className.replace(/border-l-\S+/g, '');
      entry.className = 'log-entry border-l-2 ' + getStatusBorderColor(status) + ' rounded-r-lg bg-slate-800/30 cursor-pointer' + (entry.classList.contains('expanded') ? ' expanded' : '');

      if (msg) {
        msg.textContent = message || status;
      }

      var targetUrl;
      if (status === 'forwarding' && forwardTarget) {
        forwardTarget.textContent = message || '';
        targetUrl = message || '';
      }

      if (status === 'success' || status === 'sent-no-cors' || status === 'error' || status === 'skipped' || status === 'handled-other-tab' || status === 'error-other-tab') {
        if (forwardResult) {
          forwardResult.textContent = message || status;
        }
      }

      // Persist status update to localStorage
      var webhookId = entry.dataset.webhookId;
      if (webhookId) {
        updateLogEntryInStore(webhookId, status, message || status, targetUrl);
      }
    }

    function clearLog() {
      logContainer.innerHTML = '';
      logCount = 0;
      logEntries = [];
      document.getElementById('log-count-badge').textContent = '0';
      document.getElementById('log-empty').classList.remove('hidden');
      try { localStorage.removeItem(LOG_STORAGE_KEY); } catch (e) {}
    }

    // ─── Handle Webhook (core forwarding logic) ──────────────────────
    async function handleWebhook(webhook) {
      // webhook = { id, timestamp, method, path, headers, rawBodyBase64, query }
      const entry = addLogEntry(webhook);

      // Multi-tab coordination
      const broadcastChannel = getBroadcastChannel();
      if (claimedByOther.has(webhook.id)) {
        updateEntryStatus(entry, 'handled-other-tab', 'Forwarded by another tab');
        return;
      }
      broadcastChannel.postMessage({ type: 'claim', webhookId: webhook.id });
      localClaims.add(webhook.id);

      // Small delay to check if another tab claimed first
      await new Promise(function(r) { setTimeout(r, 30); });
      if (claimedByOther.has(webhook.id)) {
        localClaims.delete(webhook.id);
        updateEntryStatus(entry, 'handled-other-tab', 'Forwarded by another tab');
        return;
      }

      // Find mapping
      const target = resolveTarget(webhook.path);
      if (!target) {
        updateEntryStatus(entry, 'skipped', 'No mapping configured');
        socket.emit('webhook:ack', { channelId: channelId, lastId: webhook.id });
        return;
      }

      // Build headers (filter forbidden)
      const headers = filterHeaders(webhook.headers || {});

      // Decode body
      var body = null;
      if (webhook.rawBodyBase64) {
        try {
          var binary = atob(webhook.rawBodyBase64);
          var bytes = new Uint8Array(binary.length);
          for (var i = 0; i < binary.length; i++) bytes[i] = binary.charCodeAt(i);
          body = bytes.buffer;
        } catch (e) {
          body = null;
        }
      }

      // Build URL with query params
      var targetUrl = target;
      if (webhook.query && Object.keys(webhook.query).length > 0) {
        try {
          var url = new URL(target);
          Object.entries(webhook.query).forEach(function(pair) {
            url.searchParams.append(pair[0], pair[1]);
          });
          targetUrl = url.toString();
        } catch (e) {
          // If URL parsing fails, append manually
          var qs = Object.entries(webhook.query).map(function(pair) {
            return encodeURIComponent(pair[0]) + '=' + encodeURIComponent(pair[1]);
          }).join('&');
          targetUrl = target + (target.indexOf('?') === -1 ? '?' : '&') + qs;
        }
      }

      updateEntryStatus(entry, 'forwarding', targetUrl);

      // Try CORS fetch, fallback to no-cors
      try {
        var fetchOpts = {
          method: webhook.method,
          headers: headers,
          body: ['GET', 'HEAD'].includes(webhook.method.toUpperCase()) ? undefined : body,
        };

        var response;
        var mode = 'cors';
        try {
          response = await fetch(targetUrl, Object.assign({}, fetchOpts, { mode: 'cors' }));
          updateEntryStatus(entry, 'success', response.status + ' ' + response.statusText);
        } catch (corsErr) {
          // Fallback to no-cors
          mode = 'no-cors';
          response = await fetch(targetUrl, {
            method: webhook.method,
            body: ['GET', 'HEAD'].includes(webhook.method.toUpperCase()) ? undefined : body,
            mode: 'no-cors',
          });
          updateEntryStatus(entry, 'sent-no-cors', 'Sent (opaque response - add CORS to your server for full visibility)');
        }

        socket.emit('forward:result', { channelId: channelId, webhookId: webhook.id, success: true, mode: mode });
      } catch (err) {
        updateEntryStatus(entry, 'error', err.message);
        socket.emit('forward:result', { channelId: channelId, webhookId: webhook.id, success: false, error: err.message });
      }

      socket.emit('webhook:ack', { channelId: channelId, lastId: webhook.id });
    }

    // ─── Restore Saved Log Entries ─────────────────────────────────────
    (function restoreSavedLog() {
      var saved = loadLog();
      if (saved.length === 0) return;

      _restoringLog = true;
      logEntries = saved; // populate in-memory mirror

      // Render entries from oldest to newest (they get inserted at top,
      // so the newest will end up at the top of the list)
      for (var i = saved.length - 1; i >= 0; i--) {
        var s = saved[i];
        // Mark as restored so addLogEntry skips the localStorage write
        var webhookData = {
          id: s.id,
          timestamp: s.timestamp,
          method: s.method,
          path: s.path,
          headers: s.headers,
          rawBodyBase64: s.rawBodyBase64,
          query: s.query,
          _restored: true,
        };
        var entry = addLogEntry(webhookData);

        // Apply saved status styling
        if (s.status && s.status !== 'received') {
          // Set forward target text if we have a targetUrl
          if (s.targetUrl) {
            var ft = entry.querySelector('[data-role="forward-target"]');
            if (ft) ft.textContent = s.targetUrl;
          }
          updateEntryStatus(entry, s.status, s.statusMessage || s.status);
        }
      }
      _restoringLog = false;
    })();

    // ─── Clipboard ────────────────────────────────────────────────────
    function copyUrl() {
      var url = window.location.origin + '/w/' + channelId + '/';
      navigator.clipboard.writeText(url).then(function() {
        var btn = document.getElementById('copy-text');
        btn.textContent = 'Copied!';
        setTimeout(function() { btn.textContent = 'Copy'; }, 1500);
      }).catch(function() {
        // Fallback: select text
        var el = document.getElementById('webhook-url');
        var range = document.createRange();
        range.selectNodeContents(el);
        var sel = window.getSelection();
        sel.removeAllRanges();
        sel.addRange(range);
      });
    }

    // ─── New Channel ──────────────────────────────────────────────────
    function newChannel() {
      channelId = crypto.randomUUID();
      localStorage.setItem('wsproxy:channelId', channelId);
      window.location.href = '/ch/' + channelId;
    }
  </script>
</body>
</html>

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard - Webhook Proxy Server</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { font-family: 'Inter', system-ui, -apple-system, sans-serif; }
    .fade-in { animation: fadeIn 0.3s ease-in; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
  </style>
</head>
<body class="bg-gray-950 text-gray-100 min-h-screen">
  <!-- Header -->
  <header class="bg-gray-900 border-b border-gray-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 bg-sky-600/20 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-sky-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <h1 class="text-lg font-semibold">Webhook Proxy Server</h1>
        </div>
        <a href="/logout" class="text-sm text-gray-400 hover:text-gray-200 transition">Cerrar sesion</a>
      </div>
    </div>
  </header>

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Stats -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
        <div class="text-sm text-gray-400 mb-1">Endpoints registrados</div>
        <div class="text-3xl font-bold" id="endpoints-count"><%= endpoints.length %></div>
      </div>
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
        <div class="text-sm text-gray-400 mb-1">Clientes conectados</div>
        <div class="text-3xl font-bold" id="clients-count"><%= connectedClients %></div>
      </div>
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
        <div class="text-sm text-gray-400 mb-1">Webhooks recibidos</div>
        <div class="text-3xl font-bold" id="webhooks-count"><%= activityLog.length %></div>
      </div>
    </div>

    <!-- Endpoints CRUD -->
    <div class="bg-gray-900 border border-gray-800 rounded-xl mb-8">
      <div class="flex items-center justify-between p-5 border-b border-gray-800">
        <h2 class="text-lg font-semibold">Endpoints</h2>
        <button onclick="showAddModal()" class="px-4 py-2 bg-sky-600 hover:bg-sky-700 text-white text-sm font-medium rounded-lg transition">
          + Nuevo Endpoint
        </button>
      </div>
      <div class="divide-y divide-gray-800" id="endpoints-list">
        <% endpoints.forEach(endpoint => { %>
          <div class="p-4 flex items-center justify-between hover:bg-gray-800/50 transition" id="endpoint-<%= endpoint.key %>">
            <div class="flex items-center gap-4">
              <span class="px-2.5 py-1 text-xs font-mono font-bold rounded-md uppercase
                <% if (endpoint.method === 'get') { %>bg-green-500/10 text-green-400 border border-green-500/20
                <% } else if (endpoint.method === 'post') { %>bg-blue-500/10 text-blue-400 border border-blue-500/20
                <% } else if (endpoint.method === 'put') { %>bg-yellow-500/10 text-yellow-400 border border-yellow-500/20
                <% } else { %>bg-red-500/10 text-red-400 border border-red-500/20<% } %>
              "><%= endpoint.method %></span>
              <div>
                <div class="font-mono text-sm"><span class="text-gray-500">/webhooks</span><%= endpoint.path %></div>
                <div class="text-xs text-gray-500 mt-0.5">key: <%= endpoint.key %></div>
              </div>
            </div>
            <div class="flex items-center gap-2">
              <button onclick="editEndpoint('<%= endpoint.key %>', '<%= endpoint.path %>', '<%= endpoint.method %>')" class="p-2 text-gray-400 hover:text-gray-200 hover:bg-gray-700 rounded-lg transition" title="Editar">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
              </button>
              <button onclick="deleteEndpoint('<%= endpoint.key %>')" class="p-2 text-gray-400 hover:text-red-400 hover:bg-gray-700 rounded-lg transition" title="Eliminar">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
              </button>
            </div>
          </div>
        <% }) %>
      </div>
    </div>

    <!-- Activity Log -->
    <div class="bg-gray-900 border border-gray-800 rounded-xl">
      <div class="flex items-center justify-between p-5 border-b border-gray-800">
        <h2 class="text-lg font-semibold">Actividad reciente</h2>
        <span class="text-xs text-gray-500" id="log-status">En tiempo real</span>
      </div>
      <div class="divide-y divide-gray-800 max-h-96 overflow-y-auto" id="activity-log">
        <% if (activityLog.length === 0) { %>
          <div class="p-8 text-center text-gray-500" id="empty-log">
            Sin actividad todavia
          </div>
        <% } %>
        <% activityLog.forEach(entry => { %>
          <div class="p-3 px-5 flex items-center gap-4 text-sm">
            <span class="px-2 py-0.5 text-xs font-mono font-bold rounded uppercase
              <% if (entry.method === 'GET') { %>bg-green-500/10 text-green-400
              <% } else { %>bg-blue-500/10 text-blue-400<% } %>
            "><%= entry.method %></span>
            <span class="font-mono text-gray-300 flex-1"><%= entry.path %></span>
            <span class="text-gray-500 text-xs"><%= new Date(entry.timestamp).toLocaleTimeString() %></span>
          </div>
        <% }) %>
      </div>
    </div>
  </main>

  <!-- Modal for Add/Edit -->
  <div id="modal" class="fixed inset-0 bg-black/60 backdrop-blur-sm hidden items-center justify-center z-50" style="display:none;">
    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6 w-full max-w-md mx-4 shadow-2xl">
      <h3 class="text-lg font-semibold mb-4" id="modal-title">Nuevo Endpoint</h3>
      <form id="endpoint-form" onsubmit="submitEndpoint(event)">
        <input type="hidden" id="form-original-key" value="">
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-300 mb-1">Key (identificador unico)</label>
          <input type="text" id="form-key" required placeholder="ej: mercadopago-notifications"
            class="w-full px-3 py-2 bg-gray-800 border border-gray-700 rounded-lg text-gray-100 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-sky-500 focus:border-transparent text-sm">
        </div>
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-300 mb-1">Path</label>
          <input type="text" id="form-path" required placeholder="ej: /mercadopago/notifications"
            class="w-full px-3 py-2 bg-gray-800 border border-gray-700 rounded-lg text-gray-100 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-sky-500 focus:border-transparent text-sm">
        </div>
        <div class="mb-6">
          <label class="block text-sm font-medium text-gray-300 mb-1">Metodo HTTP</label>
          <select id="form-method"
            class="w-full px-3 py-2 bg-gray-800 border border-gray-700 rounded-lg text-gray-100 focus:outline-none focus:ring-2 focus:ring-sky-500 focus:border-transparent text-sm">
            <option value="get">GET</option>
            <option value="post" selected>POST</option>
            <option value="put">PUT</option>
            <option value="delete">DELETE</option>
          </select>
        </div>
        <div class="flex gap-3">
          <button type="button" onclick="hideModal()" class="flex-1 py-2.5 px-4 bg-gray-800 hover:bg-gray-700 text-gray-300 font-medium rounded-lg transition text-sm">Cancelar</button>
          <button type="submit" class="flex-1 py-2.5 px-4 bg-sky-600 hover:bg-sky-700 text-white font-medium rounded-lg transition text-sm">Guardar</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    const API_HEADERS = { "Content-Type": "application/json" };

    // --- Modal ---
    function showAddModal() {
      document.getElementById("modal-title").textContent = "Nuevo Endpoint";
      document.getElementById("form-key").value = "";
      document.getElementById("form-key").disabled = false;
      document.getElementById("form-path").value = "";
      document.getElementById("form-method").value = "post";
      document.getElementById("form-original-key").value = "";
      document.getElementById("modal").style.display = "flex";
    }

    function editEndpoint(key, path, method) {
      document.getElementById("modal-title").textContent = "Editar Endpoint";
      document.getElementById("form-key").value = key;
      document.getElementById("form-key").disabled = true;
      document.getElementById("form-path").value = path;
      document.getElementById("form-method").value = method;
      document.getElementById("form-original-key").value = key;
      document.getElementById("modal").style.display = "flex";
    }

    function hideModal() {
      document.getElementById("modal").style.display = "none";
    }

    async function submitEndpoint(e) {
      e.preventDefault();
      const originalKey = document.getElementById("form-original-key").value;
      const key = document.getElementById("form-key").value;
      const path = document.getElementById("form-path").value;
      const method = document.getElementById("form-method").value;

      try {
        if (originalKey) {
          await fetch("/api/endpoints/" + encodeURIComponent(originalKey), {
            method: "PUT",
            headers: API_HEADERS,
            body: JSON.stringify({ path, method }),
          });
        } else {
          await fetch("/api/endpoints", {
            method: "POST",
            headers: API_HEADERS,
            body: JSON.stringify({ path, method, key }),
          });
        }
        hideModal();
        location.reload();
      } catch (err) {
        alert("Error: " + err.message);
      }
    }

    async function deleteEndpoint(key) {
      if (!confirm("Eliminar endpoint " + key + "?")) return;
      try {
        await fetch("/api/endpoints/" + encodeURIComponent(key), { method: "DELETE" });
        location.reload();
      } catch (err) {
        alert("Error: " + err.message);
      }
    }

    // --- Socket.IO live updates (optional, progressive enhancement) ---
    (function() {
      const script = document.createElement("script");
      script.src = "/socket.io/socket.io.js";
      script.onload = function() {
        // Read secret from cookie for socket auth
        const cookies = document.cookie.split(";").reduce((acc, c) => {
          const [k, v] = c.trim().split("=");
          acc[k] = v;
          return acc;
        }, {});

        // We connect without auth for the dashboard (server-side rendering handles auth)
        // The dashboard just listens for broadcast events
        // For live updates, we'll use polling instead
        setInterval(async () => {
          try {
            const res = await fetch("/api/status");
            if (res.ok) {
              const data = await res.json();
              document.getElementById("clients-count").textContent = data.connectedClients;
              document.getElementById("endpoints-count").textContent = data.endpointsCount;
            }
          } catch(e) {}
        }, 5000);
      };
      document.head.appendChild(script);

      // Poll for new activity
      let lastCount = <%= activityLog.length %>;
      setInterval(async () => {
        try {
          const res = await fetch("/api/status");
          if (res.ok) {
            const data = await res.json();
            const newCount = data.recentActivity.length;
            if (newCount !== lastCount) {
              lastCount = newCount;
              const logEl = document.getElementById("activity-log");
              const emptyLog = document.getElementById("empty-log");
              if (emptyLog) emptyLog.remove();

              logEl.innerHTML = "";
              data.recentActivity.forEach(entry => {
                const colorClass = entry.method === "GET"
                  ? "bg-green-500/10 text-green-400"
                  : "bg-blue-500/10 text-blue-400";
                logEl.innerHTML += `
                  <div class="p-3 px-5 flex items-center gap-4 text-sm fade-in">
                    <span class="px-2 py-0.5 text-xs font-mono font-bold rounded uppercase ${colorClass}">${entry.method}</span>
                    <span class="font-mono text-gray-300 flex-1">${entry.path}</span>
                    <span class="text-gray-500 text-xs">${new Date(entry.timestamp).toLocaleTimeString()}</span>
                  </div>`;
              });
              document.getElementById("webhooks-count").textContent = newCount;
            }
          }
        } catch(e) {}
      }, 3000);
    })();
  </script>
</body>
</html>
